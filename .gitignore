# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Lockfiles - keep
# (Cargo.lock IS committed for binaries; this workspace has bins so we keep it)

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Apple build outputs
apple/build/
apple/DerivedData/
apple/*.xcodeproj/
apple/*.xcworkspace/
*.xcframework/
# Fallback DerivedData location if Xcode is invoked outside `make app`
# (Makefile pins DerivedData to apple/build/, but Xcode.app defaults to a
# root-level build/ when opened directly).
/build/
DerivedData/
# UniFFI-generated Swift bindings — regenerated by scripts/build-xcframework.sh
apple/DubShared/Sources/DubCore/Generated/
# Swift Package Manager build state inside the package
apple/DubShared/.build/
apple/DubShared/.swiftpm/
apple/DubShared/Package.resolved

# Test / coverage outputs
coverage/
*.profraw
*.profdata
target/llvm-cov-target/

# Fuzz outputs
fuzz/target/
fuzz/corpus/
fuzz/artifacts/

# Local logs / dumps
# Rig capture recordings at the repo root (deckA.wav etc.) — multi-MB,
# session-specific, replayed locally via the dub-engine replay harness.
# Committed wav fixtures live under crates/*/tests/fixtures/.
/*.wav
# Personal DJ-library exports dropped at the repo root for importer
# validation (Traktor NML, iTunes/rekordbox XML). Never committed — they
# hold the developer's real library; anonymised golden fixtures live under
# crates/dub-library/tests/fixtures/.
/*.nml
/iTunes Library.xml
/rekordbox*.xml
*.log
crashes/
.cursor/settings.json
# Claude Code: share settings.json + hooks/, keep per-user overrides local
.claude/settings.local.json

# Env / secrets
.env
.env.local
*.pem
*.code-workspace

# Apple developer artifacts
ExportOptions.plist
*.p12

# SwiftUI snapshot reference images — kept local while the
# performance UI is in flux (C-31). Recommit fresh goldens as the
# regression baseline once the surface stabilises.
apple/DubTests/__Snapshots__/
